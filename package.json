{
  "name": "hardwallet-ai-agent",
  "version": "1.0.0",
  "description": "Vault — On-device AI agent for hardware cryptocurrency wallets. ETH Prague 2026.",
  "type": "module",
  "main": "src/agent/index.js",
  "scripts": {
    "start": "node src/agent/index.js",
    "dev": "node --watch src/agent/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^firmware/mock/(.*)$": "<rootDir>/firmware/mock/$1"
    }
  },
  "keywords": [
    "ethereum",
    "hardware-wallet",
    "ai-agent",
    "web3",
    "ens",
    "hackathon",
    "ethprague"
  ],
  "author": "ETH Prague 2026",
  "license": "MIT"
}
