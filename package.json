{
  "name": "hardwallet-ai-agent",
  "version": "1.0.0",
  "description": "Vault — On-device AI agent for hardware cryptocurrency wallets. ETH Prague 2026.",
  "type": "module",
  "main": "src/agent/index.js",
  "scripts": {
    "start":           "node --env-file=.env src/agent/index.js",
    "dev":             "node --env-file=.env --watch src/agent/index.js",
    "agent":           "node --env-file=.env dev/run.js",
    "scenario":        "node --env-file=.env dev/scenario.js",
    "scenario:real":   "node --env-file=.env dev/scenario-real.js",
    "test":            "node --env-file=.env --experimental-vm-modules node_modules/.bin/jest",
    "test:watch":      "node --env-file=.env --experimental-vm-modules node_modules/.bin/jest --watch",
    "lint":            "eslint src/ tests/",
    "lint:fix":        "eslint src/ tests/ --fix"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^firmware/mock/(.*)$": "<rootDir>/firmware/mock/$1"
    }
  },
  "keywords": [
    "ethereum",
    "hardware-wallet",
    "ai-agent",
    "web3",
    "ens",
    "hackathon",
    "ethprague"
  ],
  "author": "ETH Prague 2026",
  "license": "MIT"
}
