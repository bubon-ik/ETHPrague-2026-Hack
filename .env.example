# ─── Vault AI Agent — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── LLM / Inference ──────────────────────────────────────────────────────────

# OpenRouter — OpenAI-compatible endpoint that proxies 200+ models
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=anthropic/claude-opus-4-5

# ─── Ethereum RPC ─────────────────────────────────────────────────────────────

# JSON-RPC endpoint for Ethereum Mainnet (Alchemy / Infura / local node)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY

# Fallback RPC (optional)
RPC_URL_FALLBACK=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
INFURA_API_KEY=YOUR_INFURA_KEY

# ─── Price Oracle ─────────────────────────────────────────────────────────────

# CoinGecko API key (Pro plan — remove if using free tier)
COINGECKO_API_KEY=CG-...

# ─── ENS ──────────────────────────────────────────────────────────────────────

# Etherscan API key (used for ENS history and contract reads)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# ─── App Config ───────────────────────────────────────────────────────────────

# Environment: development | test | production
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# Chain ID to use in dev/test (1 = Ethereum Mainnet, 11155111 = Sepolia)
CHAIN_ID=1

# ─── Simba UI Config ──────────────────────────────────────────────────────────
ZEROX_API_KEY=your_0x_api_key_here
SIMBA_TAKER_ADDRESS=0x0000000000000000000000000000000000000000
