{
  "env": {
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "error",
    "no-undef": "error",
    "semi": ["error", "always"],
    "quotes": ["error", "single"],
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": "error",
    "curly": "error",
    "no-implicit-globals": "error"
  },
  "globals": {
    "wallet": "readonly",
    "rpc": "readonly",
    "price": "readonly",
    "ens": "readonly",
    "history": "readonly",
    "scheduler": "readonly",
    "ui": "readonly"
  }
}
