# OpenAI / OpenRouter (required for /api/agent/chat)
OPENAI_API_KEY=

# --- Optional: encrypted Swarm backup of agents/logs/session_history.json ---
# After each agent turn, the full history JSON is AES-256-GCM encrypted, then
# stored under key "session_history" (namespace wallet-agent-session) via swarm-kv
# (compiled JS in swarm_tests/swarm-kv/dist — run `npm install && npm run build` there).
# If required values are missing, Swarm sync is skipped (local JSON still updates).
# Aliases: BEE_URL / SWARM_NODE_URL (bee), BATCH_ID / SWARM_BATCH_ID (64 hex),
# PRIVATE_KEY (feed signing). Wallet server also merges swarm-kv/examples/.env
# for keys that are unset or empty in this file.

SWARM_KV_BEE_URL=http://127.0.0.1:1633
SWARM_KV_BATCH_ID=
SWARM_KV_PRIVATE_KEY=

# Passphrase for AES-256-GCM before upload (not the Swarm feed key).
SESSION_HISTORY_ENCRYPTION_SECRET=
# Optional alias:
# SWARM_KV_ENCRYPTION_SECRET=
